# BuildKit per-file dockerignore — applied when building client.Dockerfile.
# The default .dockerignore at the root excludes client/ (so the server
# build stays small); for the client build we need the opposite.
server/
node_modules/
**/node_modules/
**/.next/
.env
.env.*
.git
.gitignore
Dockerfile
client.Dockerfile
*.dockerignore
tasks/
supabase/
.claude/
README.md
CLAUDE.md
